#include <stdio.h>
#define MAX 20

int board[MAX];

int isSafe(int row, int col) {
    for (int i = 0; i < row; i++) {
        if (board[i] == col || (abs(board[i] - col) == abs(i - row)))
            return 0; // Conflict found
    }
    return 1;
}

int solveNQueen(int n, int row) {
    if (row == n) {
        // Print solution
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++)
                printf(j == board[i] ? "Q " : ". ");
            printf("\n");
        }
        return 1;
    }

    for (int col = 0; col < n; col++) {
        if (isSafe(row, col)) {
            board[row] = col;
            if (solveNQueen(n, row + 1))
                return 1; // Found a solution
        }
    }
    return 0; // No solution in this branch
}

int main() {
    int n;
    printf("Enter number of queens: ");
    scanf("%d", &n);

    if (!solveNQueen(n, 0))
        printf("No solution exists.\n");

    return 0;
}
